<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape>
            <corners android:radius="@dimen/vs_18" />
            <gradient
                android:angle="315"
                android:centerColor="#FFFFFFFF"
                android:endColor="#DCEAF5FF"
                android:startColor="#FFF9FDFF" />
            <stroke
                android:width="@dimen/vs_1"
                android:color="@color/apple_tv_focus" />
        </shape>
    </item>
    <item
        android:left="@dimen/vs_1"
        android:top="@dimen/vs_1"
        android:right="@dimen/vs_1"
        android:bottom="@dimen/vs_1">
        <shape>
            <corners android:radius="@dimen/vs_17" />
            <gradient
                android:angle="270"
                android:endColor="#00FFFFFF"
                android:startColor="#5EFFFFFF" />
        </shape>
    </item>
</layer-list>
