<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <layer-list>
            <item>
                <shape>
                    <corners android:radius="@dimen/vs_18" />
                    <gradient
                        android:angle="315"
                        android:centerColor="#FFFFFFFF"
                        android:endColor="#D7EAF3FF"
                        android:startColor="@color/apple_tv_chip_active" />
                    <stroke
                        android:width="@dimen/vs_1"
                        android:color="@color/apple_tv_focus" />
                </shape>
            </item>
            <item
                android:left="@dimen/vs_1"
                android:top="@dimen/vs_1"
                android:right="@dimen/vs_1"
                android:bottom="@dimen/vs_1">
                <shape>
                    <corners android:radius="@dimen/vs_16" />
                    <gradient
                        android:angle="270"
                        android:endColor="#00FFFFFF"
                        android:startColor="#59FFFFFF" />
                </shape>
            </item>
        </layer-list>
    </item>
    <item>
        <layer-list>
            <item>
                <shape>
                    <corners android:radius="@dimen/vs_18" />
                    <gradient
                        android:angle="315"
                        android:centerColor="#96303B49"
                        android:endColor="#7C18212C"
                        android:startColor="#A5212B38" />
                    <stroke
                        android:width="@dimen/vs_1"
                        android:color="@color/apple_tv_glass_edge" />
                </shape>
            </item>
            <item
                android:left="@dimen/vs_1"
                android:top="@dimen/vs_1"
                android:right="@dimen/vs_1"
                android:bottom="@dimen/vs_1">
                <shape>
                    <corners android:radius="@dimen/vs_16" />
                    <gradient
                        android:angle="270"
                        android:endColor="#00FFFFFF"
                        android:startColor="#22FFFFFF" />
                </shape>
            </item>
        </layer-list>
    </item>
</selector>
