<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true" android:state_pressed="true">
        <shape>
            <corners android:radius="@dimen/vs_30" />
            <gradient
                android:angle="315"
                android:centerColor="#E23B4754"
                android:endColor="#CF29333E"
                android:startColor="#EB3C4755" />
            <stroke android:width="@dimen/vs_1" android:color="@color/apple_tv_focus" />
        </shape>
    </item>
    <item android:state_focused="false" android:state_pressed="true">
        <shape>
            <corners android:radius="@dimen/vs_30" />
            <solid android:color="#D02B3540" />
            <stroke android:width="@dimen/vs_1" android:color="@color/apple_tv_focus" />
        </shape>
    </item>
    <item android:state_focused="true">
        <shape>
            <corners android:radius="@dimen/vs_30" />
            <gradient
                android:angle="315"
                android:centerColor="#E23B4754"
                android:endColor="#CF29333E"
                android:startColor="#EB3C4755" />
            <stroke android:width="@dimen/vs_1" android:color="@color/apple_tv_focus" />
        </shape>
    </item>
    <item android:state_focused="false" android:state_pressed="false">
        <shape>
            <corners android:radius="@dimen/vs_30" />
            <solid android:color="#2218222B" />
            <stroke android:width="@dimen/vs_1" android:color="@color/apple_tv_glass_edge" />
        </shape>
    </item>
</selector>
