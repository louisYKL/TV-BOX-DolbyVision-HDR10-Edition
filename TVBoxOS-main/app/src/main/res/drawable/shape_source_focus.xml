<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape>
            <corners android:radius="10mm" />
            <solid android:color="#E6202B39" />
            <stroke android:width="2mm" android:color="#99F6FBFF" />
        </shape>
    </item>
    <item android:state_focused="false">
        <shape>
            <corners android:radius="10mm" />
            <solid android:color="#B3182330" />
            <stroke android:width="1mm" android:color="#33D7E7FF" />
        </shape>
    </item>
</selector>
