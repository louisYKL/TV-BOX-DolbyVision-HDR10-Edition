<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:paddingLeft="@dimen/vs_28"
    android:paddingRight="@dimen/vs_28">

    <RelativeLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">

        <LinearLayout
            android:id="@+id/tvUserHome"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:baselineAligned="false"
            android:focusable="false"
            android:focusableInTouchMode="false"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <com.github.tvbox.osc.ui.tv.widget.LiquidGlassFrameLayout
                android:id="@+id/tvHistory"
                android:layout_width="0dp"
                android:layout_height="@dimen/vs_90"
                android:layout_marginStart="@dimen/vs_6"
                android:layout_marginTop="@dimen/vs_8"
                android:layout_marginEnd="@dimen/vs_6"
                android:layout_marginBottom="@dimen/vs_8"
                android:layout_weight="1"
                android:tag="contrast-focus"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:focusable="true"
                android:nextFocusLeft="@+id/tvSetting"
                android:paddingLeft="@dimen/vs_14"
                android:paddingTop="@dimen/vs_12"
                android:paddingRight="@dimen/vs_16"
                android:paddingBottom="@dimen/vs_12">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="@dimen/vs_40"
                        android:layout_height="@dimen/vs_40"
                        android:alpha="0.78"
                        android:src="@drawable/icon_history" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="@dimen/vs_8"
                        android:layout_weight="1"
                        android:ellipsize="end"
                        android:focusable="false"
                        android:focusableInTouchMode="false"
                        android:gravity="center_vertical"
                        android:includeFontPadding="false"
                        android:maxLines="1"
                        android:singleLine="true"
                        android:text="历史"
                        android:textAlignment="gravity"
                        android:textColor="@color/apple_tv_text_primary"
                        android:textSize="@dimen/ts_24" />
                </LinearLayout>
            </com.github.tvbox.osc.ui.tv.widget.LiquidGlassFrameLayout>

            <com.github.tvbox.osc.ui.tv.widget.LiquidGlassFrameLayout
                android:id="@+id/tvLive"
                android:layout_width="0dp"
                android:layout_height="@dimen/vs_90"
                android:layout_marginStart="@dimen/vs_6"
                android:layout_marginTop="@dimen/vs_8"
                android:layout_marginEnd="@dimen/vs_6"
                android:layout_marginBottom="@dimen/vs_8"
                android:layout_weight="1"
                android:tag="contrast-focus"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:focusable="true"
                android:paddingLeft="@dimen/vs_14"
                android:paddingTop="@dimen/vs_12"
                android:paddingRight="@dimen/vs_16"
                android:paddingBottom="@dimen/vs_12">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="@dimen/vs_40"
                        android:layout_height="@dimen/vs_40"
                        android:alpha="0.78"
                        android:src="@drawable/icon_live" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="@dimen/vs_8"
                        android:layout_weight="1"
                        android:ellipsize="end"
                        android:focusable="false"
                        android:focusableInTouchMode="false"
                        android:gravity="center_vertical"
                        android:includeFontPadding="false"
                        android:maxLines="1"
                        android:singleLine="true"
                        android:text="直播"
                        android:textAlignment="gravity"
                        android:textColor="@color/apple_tv_text_primary"
                        android:textSize="@dimen/ts_24" />
                </LinearLayout>
            </com.github.tvbox.osc.ui.tv.widget.LiquidGlassFrameLayout>

            <com.github.tvbox.osc.ui.tv.widget.LiquidGlassFrameLayout
                android:id="@+id/tvSearch"
                android:layout_width="0dp"
                android:layout_height="@dimen/vs_90"
                android:layout_marginStart="@dimen/vs_6"
                android:layout_marginTop="@dimen/vs_8"
                android:layout_marginEnd="@dimen/vs_6"
                android:layout_marginBottom="@dimen/vs_8"
                android:layout_weight="1"
                android:tag="contrast-focus"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:focusable="true"
                android:paddingLeft="@dimen/vs_14"
                android:paddingTop="@dimen/vs_12"
                android:paddingRight="@dimen/vs_16"
                android:paddingBottom="@dimen/vs_12">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="@dimen/vs_40"
                        android:layout_height="@dimen/vs_40"
                        android:alpha="0.78"
                        android:src="@drawable/icon_search" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="@dimen/vs_8"
                        android:layout_weight="1"
                        android:ellipsize="end"
                        android:focusable="false"
                        android:focusableInTouchMode="false"
                        android:gravity="center_vertical"
                        android:includeFontPadding="false"
                        android:maxLines="1"
                        android:singleLine="true"
                        android:text="搜索"
                        android:textAlignment="gravity"
                        android:textColor="@color/apple_tv_text_primary"
                        android:textSize="@dimen/ts_24" />
                </LinearLayout>
            </com.github.tvbox.osc.ui.tv.widget.LiquidGlassFrameLayout>

            <com.github.tvbox.osc.ui.tv.widget.LiquidGlassFrameLayout
                android:id="@+id/tvPush"
                android:layout_width="0dp"
                android:layout_height="@dimen/vs_90"
                android:layout_marginStart="@dimen/vs_6"
                android:layout_marginTop="@dimen/vs_8"
                android:layout_marginEnd="@dimen/vs_6"
                android:layout_marginBottom="@dimen/vs_8"
                android:layout_weight="1"
                android:tag="contrast-focus"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:focusable="true"
                android:paddingLeft="@dimen/vs_14"
                android:paddingTop="@dimen/vs_12"
                android:paddingRight="@dimen/vs_16"
                android:paddingBottom="@dimen/vs_12">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="@dimen/vs_40"
                        android:layout_height="@dimen/vs_40"
                        android:alpha="0.78"
                        android:src="@drawable/icon_push" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="@dimen/vs_8"
                        android:layout_weight="1"
                        android:ellipsize="end"
                        android:focusable="false"
                        android:focusableInTouchMode="false"
                        android:gravity="center_vertical"
                        android:includeFontPadding="false"
                        android:maxLines="1"
                        android:singleLine="true"
                        android:text="推送"
                        android:textAlignment="gravity"
                        android:textColor="@color/apple_tv_text_primary"
                        android:textSize="@dimen/ts_24" />
                </LinearLayout>
            </com.github.tvbox.osc.ui.tv.widget.LiquidGlassFrameLayout>

            <com.github.tvbox.osc.ui.tv.widget.LiquidGlassFrameLayout
                android:id="@+id/tvFavorite"
                android:layout_width="0dp"
                android:layout_height="@dimen/vs_90"
                android:layout_marginStart="@dimen/vs_6"
                android:layout_marginTop="@dimen/vs_8"
                android:layout_marginEnd="@dimen/vs_6"
                android:layout_marginBottom="@dimen/vs_8"
                android:layout_weight="1"
                android:tag="contrast-focus"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:focusable="true"
                android:paddingLeft="@dimen/vs_14"
                android:paddingTop="@dimen/vs_12"
                android:paddingRight="@dimen/vs_16"
                android:paddingBottom="@dimen/vs_12">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="@dimen/vs_40"
                        android:layout_height="@dimen/vs_40"
                        android:alpha="0.78"
                        android:src="@drawable/icon_collect" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="@dimen/vs_8"
                        android:layout_weight="1"
                        android:ellipsize="end"
                        android:focusable="false"
                        android:focusableInTouchMode="false"
                        android:gravity="center_vertical"
                        android:includeFontPadding="false"
                        android:maxLines="1"
                        android:singleLine="true"
                        android:text="收藏"
                        android:textAlignment="gravity"
                        android:textColor="@color/apple_tv_text_primary"
                        android:textSize="@dimen/ts_24" />
                </LinearLayout>
            </com.github.tvbox.osc.ui.tv.widget.LiquidGlassFrameLayout>

            <com.github.tvbox.osc.ui.tv.widget.LiquidGlassFrameLayout
                android:id="@+id/tvSetting"
                android:layout_width="0dp"
                android:layout_height="@dimen/vs_90"
                android:layout_marginStart="@dimen/vs_6"
                android:layout_marginTop="@dimen/vs_8"
                android:layout_marginEnd="@dimen/vs_6"
                android:layout_marginBottom="@dimen/vs_8"
                android:layout_weight="1"
                android:tag="contrast-focus"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:focusable="true"
                android:nextFocusRight="@+id/tvHistory"
                android:paddingLeft="@dimen/vs_14"
                android:paddingTop="@dimen/vs_12"
                android:paddingRight="@dimen/vs_16"
                android:paddingBottom="@dimen/vs_12">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="@dimen/vs_40"
                        android:layout_height="@dimen/vs_40"
                        android:alpha="0.78"
                        android:src="@drawable/icon_setting" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="@dimen/vs_8"
                        android:layout_weight="1"
                        android:ellipsize="end"
                        android:focusable="false"
                        android:focusableInTouchMode="false"
                        android:gravity="center_vertical"
                        android:includeFontPadding="false"
                        android:maxLines="1"
                        android:singleLine="true"
                        android:text="设置"
                        android:textAlignment="gravity"
                        android:textColor="@color/apple_tv_text_primary"
                        android:textSize="@dimen/ts_24" />
                </LinearLayout>
            </com.github.tvbox.osc.ui.tv.widget.LiquidGlassFrameLayout>

        </LinearLayout>

        <com.owen.tvrecyclerview.widget.TvRecyclerView
            android:id="@+id/tvHotList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/tvUserHome"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:visibility="gone"
            app:tv_horizontalSpacingWithMargins="@dimen/vs_26"
            app:tv_selectedItemIsCentered="true"
            app:tv_verticalSpacingWithMargins="@dimen/vs_22" />
    </RelativeLayout>

</RelativeLayout>
