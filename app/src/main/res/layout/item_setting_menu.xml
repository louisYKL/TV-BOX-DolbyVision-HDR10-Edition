    android:layout_height="wrap_content"
    android:layout_marginTop="@dimen/vs_4"
    android:layout_marginBottom="@dimen/vs_20"
    android:tag="contrast-focus"
    android:focusable="true"
    android:focusableInTouchMode="true">

    <TextView
        android:id="@+id/tvName"
        android:layout_width="match_parent"
        android:layout_height="@dimen/vs_64"
        android:gravity="center_vertical"
        android:paddingStart="@dimen/vs_26"
        android:paddingEnd="@dimen/vs_26"
        android:singleLine="true"
        android:textColor="@color/apple_tv_text_primary"
        android:textSize="@dimen/ts_22"
        android:textStyle="bold" />
</com.github.tvbox.osc.ui.tv.widget.LiquidGlassFrameLayout>
