<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rootView"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:descendantFocusability="beforeDescendants"
    android:focusable="true"
    android:focusableInTouchMode="true">

    <LinearLayout
        android:id="@+id/top_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:background="@drawable/bg_apple_tv_scrim_top"
        android:orientation="horizontal"
        android:paddingStart="@dimen/vs_20"
        android:paddingTop="@dimen/vs_14"
        android:paddingEnd="@dimen/vs_20"
        android:paddingBottom="@dimen/vs_20"
        android:visibility="gone"
        tools:visibility="visible">

        <LinearLayout
            android:id="@+id/tv_top_l_container"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="3"
            android:orientation="vertical"
            android:tag="tv_top_container"
            android:visibility="gone"
            tools:visibility="visible">

            <TextView
                android:id="@+id/tv_info_name1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:singleLine="true"
                android:textColor="@color/apple_tv_text_primary"
                android:textSize="@dimen/ts_20"
                tools:text="片名 / 源地址" />

            <TextView
                android:id="@+id/tv_videosize"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/vs_4"
                android:ellipsize="end"
                android:maxLines="1"
                android:tag="vod_video_size"
                android:textColor="@color/apple_tv_text_secondary"
                android:textSize="@dimen/ts_18"
                tools:text="3840 x 2160 HDR" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/tv_top_r_container"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="2"
            android:gravity="end"
            android:orientation="vertical"
            android:tag="tv_top_container"
            android:visibility="gone"
            tools:visibility="visible">

            <LinearLayout
                android:id="@+id/tv_screen_display"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_apple_tv_overlay"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="@dimen/vs_14"
                android:paddingTop="@dimen/vs_8"
                android:paddingEnd="@dimen/vs_14"
                android:paddingBottom="@dimen/vs_8">

                <TextView
                    android:id="@+id/net_play_speed"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingEnd="@dimen/vs_10"
                    android:textColor="@color/apple_tv_text_primary"
                    android:textSize="@dimen/ts_18"
                    tools:text="78Mbps" />

                <TextView
                    android:id="@+id/tv_seek_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingEnd="@dimen/vs_10"
                    android:tag="vod_control_pause_time"
                    android:textColor="@color/apple_tv_text_primary"
                    android:textSize="@dimen/ts_18"
                    tools:text="00:42:10 / 01:35:08" />

                <TextView
                    android:id="@+id/tv_sys_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:tag="vod_control_pause_time"
                    android:textColor="@color/apple_tv_text_primary"
                    android:textSize="@dimen/ts_18"
                    tools:text="20:30" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_play_load_net_speed_right_top"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/vs_6"
                android:textColor="@color/apple_tv_text_secondary"
                android:textSize="@dimen/ts_16"
                tools:text="0KB/s" />
        </LinearLayout>
    </LinearLayout>

    <com.github.tvbox.osc.subtitle.widget.SimpleSubtitleView
        android:id="@+id/subtitle_view"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:gravity="center"
        android:paddingStart="@dimen/vs_24"
        android:paddingTop="@dimen/vs_15"
        android:paddingEnd="@dimen/vs_24"
        android:paddingBottom="@dimen/vs_110"
        android:textColor="#ffffff"
        android:textSize="16sp"
        android:textStyle="bold" />

    <LinearLayout
        android:id="@+id/bottom_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginStart="@dimen/vs_20"
        android:layout_marginEnd="@dimen/vs_20"
        android:layout_marginBottom="@dimen/vs_18"
        android:background="@drawable/bg_apple_tv_overlay"
        android:orientation="vertical"
        android:paddingStart="@dimen/vs_20"
        android:paddingTop="@dimen/vs_18"
        android:paddingEnd="@dimen/vs_20"
        android:paddingBottom="@dimen/vs_14"
        android:visibility="gone"
        tools:visibility="visible">

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fillViewport="true"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/play_btn_group"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/play_resume_anchor"
                    android:layout_width="1dp"
                    android:layout_height="1dp"
                    android:alpha="0"
                    android:clickable="false"
                    android:focusable="false"
                    android:focusableInTouchMode="false"
                    android:importantForAccessibility="no"
                    android:nextFocusDown="@id/play_next"
                    android:nextFocusLeft="@id/play_next"
                    android:nextFocusRight="@id/play_next"
                    android:nextFocusUp="@id/play_next" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/vs_8"
                    android:text="播放"
                    android:textColor="@color/apple_tv_text_secondary"
                    android:textSize="@dimen/ts_18" />

                <com.github.tvbox.osc.ui.tv.widget.LiquidGlassTextView
                    android:id="@+id/play_next"
                    style="@style/AppleTvControlChip"
                    android:text="下一集" />

                <com.github.tvbox.osc.ui.tv.widget.LiquidGlassTextView
                    android:id="@+id/play_pre"
                    style="@style/AppleTvControlChip"
                    android:text="上一集" />

                <com.github.tvbox.osc.ui.tv.widget.LiquidGlassTextView
                    android:id="@+id/play_retry"
                    style="@style/AppleTvControlChip"
                    android:text="重播" />

                <com.github.tvbox.osc.ui.tv.widget.LiquidGlassTextView
                    android:id="@+id/play_refresh"
                    style="@style/AppleTvControlChip"
                    android:text="刷新" />

                <com.github.tvbox.osc.ui.tv.widget.LiquidGlassTextView
                    android:id="@+id/play_scale"
                    style="@style/AppleTvControlChip"
                    android:text="16:9" />

                <com.github.tvbox.osc.ui.tv.widget.LiquidGlassTextView
                    android:id="@+id/play_speed"
                    style="@style/AppleTvControlChip"
                    android:text="x1.0" />

                <com.github.tvbox.osc.ui.tv.widget.LiquidGlassTextView
                    android:id="@+id/play_player"
                    style="@style/AppleTvControlChip"
                    android:text="系统播放器" />

                <TextView
                    android:id="@+id/play_time_start_end_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/vs_10"
                    android:layout_marginEnd="@dimen/vs_8"
                    android:text="片头尾"
                    android:textColor="@color/apple_tv_text_secondary"
                    android:textSize="@dimen/ts_18" />

                <com.github.tvbox.osc.ui.tv.widget.LiquidGlassTextView
                    android:id="@+id/play_time_start"
                    style="@style/AppleTvControlChip"
                    android:text="01:00" />

                <com.github.tvbox.osc.ui.tv.widget.LiquidGlassTextView
                    android:id="@+id/play_time_end"
                    style="@style/AppleTvControlChip"
                    android:text="01:00" />

                <com.github.tvbox.osc.ui.tv.widget.LiquidGlassTextView
                    android:id="@+id/play_time_reset"
                    style="@style/AppleTvControlChip"
                    android:text="重置" />

                <com.github.tvbox.osc.ui.tv.widget.LiquidGlassTextView
                    android:id="@+id/zimu_select"
                    style="@style/AppleTvControlChip"
                    android:text="字幕" />

                <com.github.tvbox.osc.ui.tv.widget.LiquidGlassTextView
                    android:id="@+id/audio_track_select"
                    style="@style/AppleTvControlChip"
                    android:text="音轨"
                    android:visibility="gone" />

                <com.github.tvbox.osc.ui.tv.widget.LiquidGlassTextView
                    android:id="@+id/landscape_portrait"
                    style="@style/AppleTvControlChip"
                    android:text="横竖屏"
                    android:visibility="gone" />

                <com.github.tvbox.osc.ui.tv.widget.LiquidGlassTextView
                    android:id="@+id/screen_display"
                    style="@style/AppleTvControlChip"
                    android:text="屏显" />
            </LinearLayout>
        </HorizontalScrollView>

        <LinearLayout
            android:id="@+id/parse_root"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/vs_12"
            android:orientation="horizontal"
            android:visibility="gone"
            tools:visibility="visible">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginEnd="@dimen/vs_8"
                android:text="解析"
                android:textColor="@color/apple_tv_text_secondary"
                android:textSize="@dimen/ts_18" />

            <com.owen.tvrecyclerview.widget.TvRecyclerView
                android:id="@+id/mGridParseView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipChildren="false"
                android:clipToPadding="false"
                app:tv_horizontalSpacingWithMargins="@dimen/vs_8"
                app:tv_selectedItemIsCentered="true"
                app:tv_verticalSpacingWithMargins="@dimen/vs_8" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/vs_14"
            android:baselineAligned="false"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/curr_time"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="end|center_vertical"
                android:includeFontPadding="false"
                android:minWidth="48dp"
                android:textColor="@color/apple_tv_text_primary"
                android:textSize="@dimen/ts_18"
                tools:text="00:00" />

            <SeekBar
                android:id="@+id/seekBar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="16"
                android:background="@null"
                android:focusable="false"
                android:focusableInTouchMode="false"
                android:max="1000"
                android:maxHeight="@dimen/vs_8"
                android:minHeight="@dimen/vs_8"
                android:paddingVertical="@dimen/vs_2"
                android:progressDrawable="@drawable/shape_player_control_vod_seek"
                android:thumb="@drawable/shape_player_control_vod_seek_thumb" />

            <TextView
                android:id="@+id/total_time"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="start|center_vertical"
                android:includeFontPadding="false"
                android:minWidth="48dp"
                android:textColor="@color/apple_tv_text_primary"
                android:textSize="@dimen/ts_18"
                tools:text="01:00" />
        </LinearLayout>
    </LinearLayout>

    <FrameLayout
        android:id="@+id/tv_pause_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:tag="vod_control_pause"
        android:visibility="gone"
        tools:visibility="visible">

        <TextView
            android:id="@+id/tv_info_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|start"
            android:layout_marginStart="@dimen/vs_24"
            android:layout_marginTop="@dimen/vs_24"
            android:maxLines="3"
            android:padding="@dimen/vs_12"
            android:textColor="@color/apple_tv_text_primary"
            android:textSize="@dimen/ts_18"
            tools:text="http://" />

        <LinearLayout
            android:layout_width="@dimen/vs_300"
            android:layout_height="@dimen/vs_200"
            android:layout_gravity="center"
            android:background="@drawable/bg_apple_tv_overlay"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="@dimen/vs_60"
                android:layout_height="@dimen/vs_60"
                android:src="@drawable/icon_play" />

            <TextView
                android:id="@+id/tv_pause_progress_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/vs_20"
                android:tag="vod_control_pause_t"
                android:textColor="@color/apple_tv_text_primary"
                android:textSize="@dimen/ts_30"
                tools:text="100" />
        </LinearLayout>
    </FrameLayout>

    <TextView
        android:id="@+id/tv_slide_progress_text"
        android:layout_width="@dimen/vs_220"
        android:layout_height="@dimen/vs_110"
        android:layout_gravity="center"
        android:background="@drawable/bg_apple_tv_overlay"
        android:gravity="center"
        android:textColor="@color/apple_tv_text_primary"
        android:textSize="@dimen/ts_30"
        android:visibility="gone"
        tools:text="100" />

    <LinearLayout
        android:id="@+id/tv_progress_container"
        android:layout_width="@dimen/vs_300"
        android:layout_height="@dimen/vs_200"
        android:layout_gravity="center"
        android:background="@drawable/bg_apple_tv_overlay"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone"
        tools:visibility="visible">

        <ImageView
            android:id="@+id/tv_progress_icon"
            android:layout_width="@dimen/vs_60"
            android:layout_height="@dimen/vs_60"
            tools:src="@drawable/icon_back" />

        <TextView
            android:id="@+id/tv_progress_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/vs_20"
            android:textColor="@color/apple_tv_text_primary"
            android:textSize="@dimen/ts_30"
            tools:text="100" />
    </LinearLayout>

    <ProgressBar
        android:layout_width="@dimen/vs_50"
        android:layout_height="@dimen/vs_50"
        android:layout_gravity="center"
        android:indeterminateBehavior="repeat"
        android:indeterminateDrawable="@drawable/anim_loading"
        android:indeterminateOnly="true"
        android:tag="vod_control_loading"
        android:visibility="gone" />

    <TextView
        android:id="@+id/tv_play_load_net_speed"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="@dimen/vs_42"
        android:textColor="@color/apple_tv_text_secondary"
        android:textSize="@dimen/ts_18"
        tools:text="0KB/s" />

    <ImageView
        android:id="@+id/tv_back"
        android:layout_width="@dimen/vs_82"
        android:layout_height="@dimen/vs_82"
        android:layout_gravity="start|center_vertical"
        android:clickable="false"
        android:focusable="false"
        android:focusableInTouchMode="false"
        android:paddingHorizontal="@dimen/vs_20"
        android:src="@drawable/icon_back"
        android:visibility="invisible" />

    <ImageView
        android:id="@+id/tv_lock"
        android:layout_width="@dimen/vs_82"
        android:layout_height="@dimen/vs_82"
        android:layout_gravity="end|center_vertical"
        android:clickable="false"
        android:focusable="false"
        android:focusableInTouchMode="false"
        android:paddingHorizontal="@dimen/vs_20"
        android:src="@drawable/icon_unlock"
        android:visibility="invisible" />

    <FrameLayout
        android:id="@+id/play_speed_3_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="@drawable/bg_speed_indicator"
        android:padding="8dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/tv_speed_3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="3.0 X"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />
    </FrameLayout>
</FrameLayout>
