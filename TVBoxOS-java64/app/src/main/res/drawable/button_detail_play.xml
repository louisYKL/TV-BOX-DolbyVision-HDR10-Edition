<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape>
            <corners android:radius="@dimen/vs_18" />
            <gradient
                android:angle="315"
                android:centerColor="#FFFFFFFF"
                android:endColor="#D6E8F5FF"
                android:startColor="#FFF8FDFF" />
            <stroke android:width="@dimen/vs_1" android:color="@color/apple_tv_focus" />
        </shape>
    </item>
    <item android:state_focused="false">
        <shape>
            <corners android:radius="@dimen/vs_18" />
            <gradient
                android:angle="315"
                android:centerColor="#AB25303B"
                android:endColor="#921F2831"
                android:startColor="#C71B222B" />
            <stroke android:width="@dimen/vs_1" android:color="@color/apple_tv_glass_edge" />
        </shape>
    </item>
</selector>
