<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape>
            <corners android:radius="@dimen/vs_18" />
            <solid android:color="@color/apple_tv_focus" />
            <stroke
                android:width="@dimen/vs_1"
                android:color="@color/apple_tv_focus" />
        </shape>
    </item>
    <item>
        <shape>
            <corners android:radius="@dimen/vs_18" />
            <gradient
                android:angle="270"
                android:endColor="@color/apple_tv_chip"
                android:startColor="@color/apple_tv_panel" />
            <stroke
                android:width="@dimen/vs_1"
                android:color="@color/color_33FFFFFF" />
        </shape>
    </item>
</selector>
