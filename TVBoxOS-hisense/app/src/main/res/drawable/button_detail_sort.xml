<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape>
            <corners android:radius="@dimen/vs_18" />
            <gradient
                android:angle="315"
                android:centerColor="#E33A4552"
                android:endColor="#D12A3440"
                android:startColor="#EB38424E" />
            <stroke android:width="@dimen/vs_1" android:color="@color/apple_tv_focus" />
        </shape>
    </item>
    <item android:state_focused="false">
        <shape>
            <corners android:radius="@dimen/vs_18" />
            <gradient
                android:angle="315"
                android:endColor="@color/apple_tv_accent_soft"
                android:startColor="@color/apple_tv_panel_soft" />
            <stroke android:width="@dimen/vs_1" android:color="@color/apple_tv_glass_edge" />
        </shape>
    </item>
</selector>
