<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape>
            <corners android:radius="@dimen/vs_18" />
            <gradient
                android:angle="315"
                android:centerColor="#E13A4551"
                android:endColor="#CF29333E"
                android:startColor="#E93A4553" />
            <stroke android:width="@dimen/vs_1" android:color="@color/apple_tv_focus" />
        </shape>
    </item>
    <item android:state_focused="false">
        <shape>
            <corners android:radius="@dimen/vs_18" />
            <gradient
                android:angle="315"
                android:endColor="#8E1F2730"
                android:startColor="#BF1B222B" />
            <stroke android:width="@dimen/vs_1" android:color="@color/apple_tv_glass_edge" />
        </shape>
    </item>
</selector>
